# ============================================================
# Neon (Serverless PostgreSQL)
# https://console.neon.tech → 프로젝트 생성 → Connection String 복사
# ============================================================
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ============================================================
# Auth.js (NextAuth v5)
# 아무 긴 랜덤 문자열 생성: openssl rand -base64 32
# ============================================================
AUTH_SECRET=your-auth-secret-here

# ============================================================
# 카카오 OAuth
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
# 리디렉션 URI: https://your-domain.com/api/auth/callback/kakao
# ============================================================
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ============================================================
# 사이트 URL
# ============================================================
NEXT_PUBLIC_SITE_URL=https://second-life-planner.vercel.app
AUTH_URL=https://second-life-planner.vercel.app

# ============================================================
# Phase 2 이후 (결제)
# ============================================================
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=

# ============================================================
# Phase 2 이후 (Analytics)
# ============================================================
NEXT_PUBLIC_GA_ID=
